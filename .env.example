# EdgeOne Pages AI Gateway — required for LLM access
AI_GATEWAY_API_KEY=your_api_key_here
AI_GATEWAY_BASE_URL=https://your-gateway-base-url.example.com/v1

# Persist LangGraph checkpointer + KV across local dev requests. Without
# this, each POST gets a fresh in-memory blob store and the HITL pipeline
# loses state every time you click 通过 / 重写, causing the same email to
# come back for review repeatedly. ALWAYS keep this on for local dev.
PAGES_BLOB_LOCAL_PERSIST=1

# EmailProvider selection. Default = mock (uses fixtures/inbox/*.eml).
# Set to "imap" to connect to a real mailbox.
EMAIL_PROVIDER=mock

# Required when EMAIL_PROVIDER=imap
# IMAP_HOST=imap.gmail.com
# IMAP_USER=you@example.com
# IMAP_APP_PASSWORD=app-specific-password   # Gmail: https://myaccount.google.com/apppasswords
# IMAP_PORT=993
# IMAP_USE_SSL=true
